---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Request Received" description="Your quote request has been received. We'll be in touch within 24 hours.">

  <section style="min-height:70vh; display:flex; align-items:center; justify-content:center; padding:4rem 1.5rem;">
    <div style="text-align:center; max-width:36rem;">
      <div style="width:5rem; height:5rem; border-radius:50%; background:rgba(59,154,225,0.12); display:flex; align-items:center; justify-content:center; margin:0 auto 2rem; font-size:2.5rem; color:#3B9AE1;">
        ✓
      </div>
      <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#3B9AE1; margin-bottom:0.75rem;">Request Received</p>
      <h1 class="font-display" style="font-size:clamp(2.5rem,6vw,4rem); color:#eaeaea; margin-bottom:1rem;">
        We've got it!
      </h1>
      <p style="font-size:1rem; color:#7a8090; line-height:1.65; margin-bottom:0.75rem;">
        Your quote request has been submitted. We'll review the details and get back
        to you within 24 hours with a custom quote.
      </p>
      <p id="ref-display" style="font-size:0.8rem; color:#3a3a55; font-family:monospace; margin-bottom:2.5rem;"></p>
      <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
        <a
          href="/"
          style="background:#3B9AE1; color:#fff; font-family:'Barlow Condensed',sans-serif; font-size:1rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.9rem 2rem; border-radius:8px; text-decoration:none;"
        >
          BACK TO HOME
        </a>
        <a
          href="/shop"
          style="border:2px solid #1e1e35; color:#7a8090; font-family:'Barlow Condensed',sans-serif; font-size:1rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.9rem 2rem; border-radius:8px; text-decoration:none;"
        >
          BROWSE THE SHOP
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const ref = params.get('ref');
  const el = document.getElementById('ref-display');
  if (ref && el) el.textContent = `Reference: ${ref}`;
</script>
