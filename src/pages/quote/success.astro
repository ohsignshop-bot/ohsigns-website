---
import Layout from '../../layouts/Layout.astro';
import Btn from '../../components/Btn.astro';
---

<Layout title="Request Received" description="Your quote request has been received. We'll be in touch within 24 hours.">

  <section style="min-height:70vh; display:flex; align-items:center; justify-content:center; padding:80px 24px;">
    <div style="text-align:center; max-width:440px;">
      <div class="fade-up" style="width:72px; height:72px; border-radius:50%; background:rgba(0,153,255,0.1); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:2.2rem; color:var(--blue); animation:float 4s ease-in-out infinite;">
        ✓
      </div>
      <p class="fade-up-d1 section-eyebrow">Request Received</p>
      <h1 class="fade-up-d2 font-display" style="font-size:clamp(2.4rem,6vw,3.2rem); letter-spacing:3px; color:var(--text); margin-bottom:10px;">We've Got It!</h1>
      <p class="fade-up-d3" style="font-size:0.92rem; color:var(--text-muted); line-height:1.65; margin-bottom:8px;">
        Your quote request has been submitted. We'll review the details and get back to you within 24 hours.
      </p>
      <p id="ref-display" class="fade-up-d3 font-mono" style="font-size:0.75rem; color:var(--text-dim); margin-bottom:28px;"></p>
      <div class="fade-up-d4" style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center;">
        <Btn href="/" variant="primary" size="sm">BACK TO HOME</Btn>
        <Btn href="/shop" variant="outline" size="sm">BROWSE THE SHOP</Btn>
      </div>
    </div>
  </section>

</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const ref = params.get('ref');
  const el = document.getElementById('ref-display');
  if (ref && el) el.textContent = `Reference: ${ref}`;
</script>
