---
import Layout from '../layouts/Layout.astro';

const productTypes = [
  'Banner / Vinyl Banner',
  'Vehicle Wrap (Full)',
  'Vehicle Wrap (Partial)',
  'Window Graphics / Decal',
  'Wall Mural / Wall Graphics',
  'Yard Sign',
  'Foam Board / Rigid Sign',
  'Floor Graphics',
  'Retractable Banner Stand',
  'Other / Custom',
];

const budgets = [
  'Under $200',
  '$200 – $500',
  '$500 – $1,000',
  '$1,000 – $3,000',
  '$3,000+',
  'Not sure yet',
];

const inputStyle = "width:100%; background:#151525; border:1px solid #1e1e35; border-radius:8px; padding:0.75rem 1rem; font-family:'Barlow Condensed',sans-serif; font-size:1rem; color:#eaeaea; outline:none; box-sizing:border-box;";
const labelStyle = "display:block; font-size:0.7rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#3a3a55; margin-bottom:0.5rem;";
---

<Layout title="Get a Quote" description="Request a custom quote from OH! Signs. Banners, wraps, signs & more.">

  <section style="max-width:42rem; margin:0 auto; padding:4rem 1.5rem;">
    <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#3B9AE1; margin-bottom:0.75rem;">Free Quote</p>
    <h1 class="font-display" style="font-size:clamp(2.5rem,6vw,4.5rem); color:#eaeaea; margin-bottom:1rem;">
      Let's build<br />something great.
    </h1>
    <p style="font-size:1rem; color:#7a8090; margin-bottom:2.5rem; line-height:1.6;">
      Fill out the form below and we'll get back to you within 24 hours with a detailed quote.
      The more detail you give us, the faster we can help.
    </p>

    <!-- Error message -->
    <div id="form-error" style="display:none; background:#2a0a0a; border:1px solid #E84020; color:#ff8070; font-size:0.9rem; border-radius:8px; padding:0.9rem 1.25rem; margin-bottom:1.5rem;"></div>

    <form id="quote-form" style="display:flex; flex-direction:column; gap:1.5rem;" novalidate>

      <!-- Name + Email -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
        <div>
          <label style={labelStyle} for="customer_name">Full Name <span style="color:#3B9AE1;">*</span></label>
          <input type="text" id="customer_name" name="customer_name" required placeholder="Jane Smith" style={inputStyle} />
        </div>
        <div>
          <label style={labelStyle} for="email">Email <span style="color:#3B9AE1;">*</span></label>
          <input type="email" id="email" name="email" required placeholder="jane@business.com" style={inputStyle} />
        </div>
      </div>

      <!-- Phone + Product -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
        <div>
          <label style={labelStyle} for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" style={inputStyle} />
        </div>
        <div>
          <label style={labelStyle} for="product_type">Product Type <span style="color:#3B9AE1;">*</span></label>
          <select id="product_type" name="product_type" required style={inputStyle + " cursor:pointer;"}>
            <option value="">Select a product…</option>
            {productTypes.map(p => <option value={p}>{p}</option>)}
          </select>
        </div>
      </div>

      <!-- Dimensions + Qty -->
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:1.25rem;">
        <div>
          <label style={labelStyle} for="width_in">Width (in)</label>
          <input type="number" id="width_in" name="width_in" min="0" placeholder='e.g. 48"' style={inputStyle} />
        </div>
        <div>
          <label style={labelStyle} for="height_in">Height (in)</label>
          <input type="number" id="height_in" name="height_in" min="0" placeholder='e.g. 24"' style={inputStyle} />
        </div>
        <div>
          <label style={labelStyle} for="qty">Quantity</label>
          <input type="number" id="qty" name="qty" min="1" value="1" style={inputStyle} />
        </div>
      </div>

      <!-- Budget -->
      <div>
        <label style={labelStyle} for="budget">Budget Range</label>
        <select id="budget" name="budget" style={inputStyle + " cursor:pointer;"}>
          <option value="">Select a range…</option>
          {budgets.map(b => <option value={b}>{b}</option>)}
        </select>
      </div>

      <!-- Comments -->
      <div>
        <label style={labelStyle} for="comments">Project Details</label>
        <textarea
          id="comments"
          name="comments"
          rows="4"
          placeholder="Describe your project — colors, material, intended use, deadline, any other details…"
          style={inputStyle + " resize:vertical; min-height:100px;"}
        ></textarea>
      </div>

      <!-- Artwork upload -->
      <div>
        <label style={labelStyle} for="artwork">
          Artwork / Logo <span style="color:#3a3a55; font-weight:400; text-transform:none; letter-spacing:0;">(optional)</span>
        </label>
        <div
          id="drop-zone"
          style="border:2px dashed #1e1e35; border-radius:10px; padding:2.5rem 1.5rem; text-align:center; cursor:pointer; transition:border-color 0.2s;"
        >
          <div style="font-size:2.5rem; margin-bottom:0.5rem;">📎</div>
          <p style="font-size:0.95rem; color:#7a8090; margin-bottom:0.25rem;">Drop your file here or <span style="color:#3B9AE1; font-weight:600;">browse</span></p>
          <p style="font-size:0.8rem; color:#3a3a55;">PNG, JPG, PDF, AI, SVG — max 20MB</p>
          <input type="file" id="artwork" name="artwork" accept="image/*,.pdf,.ai,.svg,.eps" style="display:none;" />
        </div>
        <div id="file-info" style="display:none; margin-top:0.5rem; font-size:0.85rem; color:#7a8090; display:none; align-items:center; gap:0.5rem;">
          <span style="color:#3B9AE1;">✓</span>
          <span id="file-name"></span>
          <button type="button" id="remove-file" style="background:none; border:none; color:#E84020; cursor:pointer; margin-left:auto; font-size:0.85rem;">Remove</button>
        </div>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        id="submit-btn"
        style="width:100%; background:#3B9AE1; color:#fff; font-family:'Barlow Condensed',sans-serif; font-size:1.1rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:1.1rem; border-radius:8px; border:none; cursor:pointer; transition:opacity 0.2s;"
      >
        SEND REQUEST
      </button>

      <p style="font-size:0.8rem; color:#3a3a55; text-align:center;">
        We'll reply within 24 hours with a detailed quote.
      </p>
    </form>
  </section>

</Layout>

<script>
  const BMS_URL = 'https://bms.ohsigns.shop';

  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('artwork') as HTMLInputElement;
  const fileInfo = document.getElementById('file-info')!;
  const fileNameEl = document.getElementById('file-name')!;
  const removeBtn = document.getElementById('remove-file')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); (dropZone as HTMLElement).style.borderColor = '#3B9AE1'; });
  dropZone.addEventListener('dragleave', () => { (dropZone as HTMLElement).style.borderColor = '#1e1e35'; });
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    (dropZone as HTMLElement).style.borderColor = '#1e1e35';
    const file = e.dataTransfer?.files[0];
    if (file) setFile(file);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) setFile(fileInput.files[0]);
  });
  removeBtn.addEventListener('click', () => {
    fileInput.value = '';
    fileInfo.style.display = 'none';
    dropZone.style.display = 'block';
  });

  function setFile(file: File) {
    fileNameEl.textContent = `${file.name} (${(file.size / 1024).toFixed(0)} KB)`;
    fileInfo.style.display = 'flex';
    dropZone.style.display = 'none';
  }

  const form = document.getElementById('quote-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorDiv = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.style.display = 'none';

    const data: Record<string, any> = {
      customer_name: (form.customer_name as HTMLInputElement).value.trim(),
      email: (form.email as HTMLInputElement).value.trim(),
      phone: (form.phone as HTMLInputElement).value.trim(),
      product_type: (form.product_type as HTMLSelectElement).value,
      width_in: parseFloat((form.width_in as HTMLInputElement).value) || 0,
      height_in: parseFloat((form.height_in as HTMLInputElement).value) || 0,
      qty: parseInt((form.qty as HTMLInputElement).value) || 1,
      budget: (form.budget as HTMLSelectElement).value,
      comments: (form.comments as HTMLTextAreaElement).value.trim(),
    };

    if (!data.customer_name || !data.email || !data.product_type) {
      errorDiv.textContent = 'Please fill in Name, Email, and Product Type.';
      errorDiv.style.display = 'block';
      return;
    }

    const file = fileInput.files?.[0];
    if (file) {
      try {
        const base64 = await new Promise<string>((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve((reader.result as string).split(',')[1]);
          reader.onerror = reject;
          reader.readAsDataURL(file);
        });
        data.artwork_base64 = base64;
        data.artwork_filename = file.name;
      } catch {
        // artwork read failed — submit without it
      }
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(`${BMS_URL}/api/public/requests`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(await res.text());
      const result = await res.json();
      window.location.href = `/quote/success?ref=${result.req_num}`;
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'SEND REQUEST';
      errorDiv.textContent = 'Something went wrong. Please try again or email us at info@ohsigns.shop.';
      errorDiv.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>
