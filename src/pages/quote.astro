---
import Layout from '../layouts/Layout.astro';

const productTypes = [
  'Banner / Vinyl Banner',
  'Vehicle Wrap (Full)',
  'Vehicle Wrap (Partial)',
  'Window Graphics / Decal',
  'Wall Mural / Wall Graphics',
  'Yard Sign',
  'Foam Board / Rigid Sign',
  'Floor Graphics',
  'Retractable Banner Stand',
  'Business Cards / Flyers',
  'Fine-Art Print / Canvas',
  'Other / Custom',
];

const budgets = [
  'Under $200',
  '$200 – $500',
  '$500 – $1,000',
  '$1,000 – $3,000',
  '$3,000+',
  'Not sure yet',
];
---

<Layout title="Get a Quote" description="Request a custom quote from OH! Signs. Banners, wraps, signs & more.">

  <section style="max-width:540px; margin:0 auto; padding:100px 24px 60px;">
    <div class="fade-up" style="text-align:center; margin-bottom:32px;">
      <p class="section-eyebrow">Free Quote</p>
      <h1 class="font-display" style="font-size:clamp(2.4rem,6vw,3.8rem); letter-spacing:3px; color:var(--text); margin-bottom:8px;">
        Let's Build<br />Something Great.
      </h1>
      <div class="accent-line" style="background:var(--yellow); margin:0 auto 14px;"></div>
      <p style="font-size:0.92rem; color:var(--text-muted); line-height:1.6;">
        Fill out the form and we'll get back to you within 24 hours with a detailed quote.
      </p>
    </div>

    <!-- Error message -->
    <div id="form-error" style="display:none; background:rgba(255,45,45,0.08); border:1px solid var(--red); color:#ff8070; font-size:0.82rem; border-radius:var(--radius-sm); padding:10px 16px; margin-bottom:14px;"></div>

    <form id="quote-form" class="fade-up-d1" style="display:flex; flex-direction:column; gap:14px;" novalidate>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
        <div>
          <label class="form-label">FULL NAME <span style="color:var(--blue);">*</span></label>
          <input type="text" id="customer_name" name="customer_name" required placeholder="Jane Smith" class="form-input" />
        </div>
        <div>
          <label class="form-label">EMAIL <span style="color:var(--blue);">*</span></label>
          <input type="email" id="email" name="email" required placeholder="jane@business.com" class="form-input" />
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
        <div>
          <label class="form-label">PHONE</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" class="form-input" />
        </div>
        <div>
          <label class="form-label">PRODUCT TYPE</label>
          <select id="product_type" name="product_type" class="form-input" style="cursor:pointer;">
            <option value="">Select a product…</option>
            {productTypes.map(p => <option value={p}>{p}</option>)}
          </select>
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px;">
        <div>
          <label class="form-label">WIDTH (IN)</label>
          <input type="number" id="width_in" name="width_in" min="0" placeholder='48"' class="form-input" />
        </div>
        <div>
          <label class="form-label">HEIGHT (IN)</label>
          <input type="number" id="height_in" name="height_in" min="0" placeholder='24"' class="form-input" />
        </div>
        <div>
          <label class="form-label">QUANTITY</label>
          <input type="number" id="qty" name="qty" min="1" value="1" class="form-input" />
        </div>
      </div>

      <div>
        <label class="form-label">BUDGET RANGE</label>
        <select id="budget" name="budget" class="form-input" style="cursor:pointer;">
          <option value="">Select a range…</option>
          {budgets.map(b => <option value={b}>{b}</option>)}
        </select>
      </div>

      <div>
        <label class="form-label">PROJECT DETAILS <span style="color:var(--blue);">*</span></label>
        <textarea id="comments" name="comments" rows="4" required placeholder="Describe your project — colors, material, intended use, deadline…" class="form-input" style="resize:vertical; min-height:80px;"></textarea>
      </div>

      <!-- Artwork -->
      <div>
        <label class="form-label">ARTWORK / LOGO <span style="color:var(--text-dim); font-weight:400; text-transform:none; letter-spacing:0;">(optional)</span></label>
        <div id="drop-zone" style="border:2px dashed var(--border); border-radius:var(--radius); padding:24px 16px; text-align:center; cursor:pointer; transition:border-color 0.2s;">
          <div style="font-size:1.8rem; margin-bottom:4px;">📎</div>
          <p style="font-size:0.85rem; color:var(--text-muted);">Drop your file here or <span style="color:var(--blue); font-weight:600;">browse</span></p>
          <p class="font-mono" style="font-size:0.65rem; color:var(--text-dim); margin-top:2px;">PNG, JPG, PDF, AI, SVG — max 20MB</p>
          <input type="file" id="artwork" name="artwork" accept="image/*,.pdf,.ai,.svg,.eps" style="display:none;" />
        </div>
        <div id="file-info" style="display:none; margin-top:6px; font-size:0.8rem; color:var(--text-muted); align-items:center; gap:6px;">
          <span style="color:var(--blue);">✓</span>
          <span id="file-name"></span>
          <button type="button" id="remove-file" style="background:none; border:none; color:var(--red); cursor:pointer; margin-left:auto; font-size:0.8rem;">Remove</button>
        </div>
      </div>

      <button type="submit" id="submit-btn" class="btn btn-primary" style="width:100%; border:none; padding:14px; font-size:1.1rem;">
        SEND REQUEST
      </button>
      <p class="font-mono" style="font-size:0.65rem; color:var(--text-dim); text-align:center; letter-spacing:1px;">We'll reply within 24 hours with a detailed quote.</p>
    </form>
  </section>

</Layout>

<script>
  const BMS_URL = 'https://bms.ohsigns.shop';

  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('artwork') as HTMLInputElement;
  const fileInfo = document.getElementById('file-info')!;
  const fileNameEl = document.getElementById('file-name')!;
  const removeBtn = document.getElementById('remove-file')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); (dropZone as HTMLElement).style.borderColor = 'var(--blue)'; });
  dropZone.addEventListener('dragleave', () => { (dropZone as HTMLElement).style.borderColor = 'var(--border)'; });
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    (dropZone as HTMLElement).style.borderColor = 'var(--border)';
    const file = e.dataTransfer?.files[0];
    if (file) setFile(file);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) setFile(fileInput.files[0]); });
  removeBtn.addEventListener('click', () => { fileInput.value = ''; fileInfo.style.display = 'none'; dropZone.style.display = 'block'; });

  function setFile(file: File) {
    fileNameEl.textContent = `${file.name} (${(file.size / 1024).toFixed(0)} KB)`;
    fileInfo.style.display = 'flex';
    dropZone.style.display = 'none';
  }

  const form = document.getElementById('quote-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorDiv = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.style.display = 'none';

    const data: Record<string, any> = {
      customer_name: (form.customer_name as HTMLInputElement).value.trim(),
      email: (form.email as HTMLInputElement).value.trim(),
      phone: (form.phone as HTMLInputElement).value.trim(),
      product_type: (form.product_type as HTMLSelectElement).value,
      width_in: parseFloat((form.width_in as HTMLInputElement).value) || 0,
      height_in: parseFloat((form.height_in as HTMLInputElement).value) || 0,
      qty: parseInt((form.qty as HTMLInputElement).value) || 1,
      budget: (form.budget as HTMLSelectElement).value,
      comments: (form.comments as HTMLTextAreaElement).value.trim(),
    };

    if (!data.customer_name || !data.email || !data.comments) {
      errorDiv.textContent = 'Please fill in Name, Email, and Project Details.';
      errorDiv.style.display = 'block';
      return;
    }

    const file = fileInput.files?.[0];
    if (file) {
      try {
        const base64 = await new Promise<string>((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve((reader.result as string).split(',')[1]);
          reader.onerror = reject;
          reader.readAsDataURL(file);
        });
        data.artwork_base64 = base64;
        data.artwork_filename = file.name;
      } catch { /* skip artwork */ }
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(`${BMS_URL}/api/public/requests`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error(await res.text());
      const result = await res.json();
      window.location.href = `/quote/success?ref=${result.req_num}`;
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'SEND REQUEST';
      errorDiv.textContent = 'Something went wrong. Please try again or email us at info@ohsigns.shop.';
      errorDiv.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });
</script>
