---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Shop" description="Shop ready-made signs, banners, and print products from OH! Signs.">

  <section style="max-width:72rem; margin:0 auto; padding:100px 24px 24px; text-align:center;">
    <p class="fade-up" style="font-family:'Bebas Neue',sans-serif; font-size:0.85rem; letter-spacing:6px; color:#707080; text-transform:uppercase; margin-bottom:16px;">Our Store</p>
    <h1 class="fade-up-d1 font-display title-layered" data-text="Ready-Made Products." style="font-size:clamp(2.5rem,6vw,4rem); letter-spacing:3px; color:#F5F5F5; margin-bottom:8px;">
      Ready-Made Products.
    </h1>
    <div class="fade-up-d2 accent-line" style="background:#3B9AE1; margin:0 auto 16px;"></div>
    <p class="fade-up-d3" style="font-size:0.95rem; color:#707080;">
      Browse and order standard products online. Need something custom?
      <a href="/quote" style="color:#3B9AE1; font-weight:600; text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Get a quote →</a>
    </p>
  </section>

  <section style="max-width:72rem; margin:0 auto; padding:16px 24px 80px; min-height:600px;">
    <div id="my-store-131689503"></div>
  </section>

</Layout>

<script is:inline>
  window.ecwid_script_defer = true;
  window.ecwid_dynamic_widgets = true;
  (function(w, d, s) {
    var js, fjs = d.getElementsByTagName(s)[0];
    if (d.getElementById('ecwid-script')) return;
    js = d.createElement(s);
    js.id = 'ecwid-script';
    js.src = 'https://app.ecwid.com/script.js?131689503';
    js.defer = true;
    fjs.parentNode.insertBefore(js, fjs);
  })(window, document, 'script');
  xProductBrowser("appId=aZAFDm27wC", "id=my-store-131689503");
</script>
