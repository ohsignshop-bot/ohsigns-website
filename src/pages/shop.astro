---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Btn from '../components/Btn.astro';
---

<Layout title="Shop" description="Shop ready-made signs, banners, and print products from OH! Signs.">

  <section style="max-width:72rem; margin:0 auto; padding:100px 24px 20px; text-align:center;">
    <p class="fade-up section-eyebrow">Our Store</p>
    <h1 class="fade-up-d1 font-display" style="font-size:clamp(2.4rem,6vw,3.8rem); letter-spacing:3px; color:var(--text); margin-bottom:8px;">
      Ready-Made Products.
    </h1>
    <div class="fade-up-d2 accent-line" style="background:var(--blue); margin:0 auto 14px;"></div>
    <p class="fade-up-d3" style="font-size:0.95rem; color:var(--text-muted);">
      Browse and order standard products online. Need something custom?
      <a href="/quote" style="color:var(--blue); font-weight:600; text-decoration:none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Get a quote →</a>
    </p>
  </section>

  <section style="max-width:72rem; margin:0 auto; padding:16px 24px 80px; min-height:600px;">
    <div id="my-store-131689503"></div>
  </section>

</Layout>

<script is:inline>
  window.ecwid_script_defer = true;
  window.ecwid_dynamic_widgets = true;
  (function(w, d, s) {
    var js, fjs = d.getElementsByTagName(s)[0];
    if (d.getElementById('ecwid-script')) return;
    js = d.createElement(s);
    js.id = 'ecwid-script';
    js.src = 'https://app.ecwid.com/script.js?131689503';
    js.defer = true;
    fjs.parentNode.insertBefore(js, fjs);
  })(window, document, 'script');
  xProductBrowser("appId=aZAFDm27wC", "id=my-store-131689503");
</script>
