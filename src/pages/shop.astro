---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Shop" description="Shop ready-made signs, banners, and print products from OH! Signs.">

  <section style="max-width:72rem; margin:0 auto; padding:4rem 1.5rem 2rem;">
    <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#3a3a55; margin-bottom:0.75rem;">Our Store</p>
    <h1 class="font-display" style="font-size:clamp(2.5rem,6vw,4.5rem); color:#eaeaea; margin-bottom:0.75rem;">
      Ready-made products.
    </h1>
    <p style="font-size:1rem; color:#7a8090;">
      Browse and order standard products online. Need something custom?
      <a href="/quote" style="color:#3B9AE1; font-weight:600; text-decoration:none;">Get a quote →</a>
    </p>
  </section>

  <!-- Ecwid store embed -->
  <section style="max-width:72rem; margin:0 auto; padding:1rem 1.5rem 5rem; min-height:600px;">
    <div id="my-store-131689503"></div>
  </section>

</Layout>

<script is:inline>
  window.ecwid_script_defer = true;
  window.ecwid_dynamic_widgets = true;
  (function(w, d, s) {
    var js, fjs = d.getElementsByTagName(s)[0];
    if (d.getElementById('ecwid-script')) return;
    js = d.createElement(s);
    js.id = 'ecwid-script';
    js.src = 'https://app.ecwid.com/script.js?131689503';
    js.defer = true;
    fjs.parentNode.insertBefore(js, fjs);
  })(window, document, 'script');
  xProductBrowser("appId=aZAFDm27wC", "id=my-store-131689503");
</script>
