---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Card from '../components/Card.astro';
import Btn from '../components/Btn.astro';
import { portfolio, videos } from '../data/portfolio';
---

<Layout title="Portfolio" description="See our recent sign projects — vehicle wraps, banners, window graphics, and more.">

  <!-- Hero -->
  <section style="padding:100px 24px 48px; text-align:center;">
    <div style="max-width:680px; margin:0 auto;">
      <p class="fade-up section-eyebrow">Our Work</p>
      <h1 class="fade-up-d1 font-display" style="font-size:clamp(2.6rem,7vw,4.5rem); line-height:1.05; letter-spacing:3px; margin-bottom:14px; color:var(--text);">
        Recent <span style="color:var(--blue);">Projects.</span>
      </h1>
      <div class="fade-up-d2 accent-line" style="background:var(--red); margin:0 auto 14px;"></div>
      <p class="fade-up-d3" style="font-size:0.95rem; color:var(--text-muted); line-height:1.7; max-width:500px; margin:0 auto;">
        From fleet wraps to storefront graphics — here's a look at some of the work we've done for local businesses.
      </p>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section style="padding:32px 24px 60px;">
    <div style="max-width:960px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:16px;">
      {portfolio.map((p, i) => (
        <Card accentColor={p.color} class={`fade-up-d${(i % 3) + 1}`}>
          <div style="width:100%; height:180px; background:rgba(20,20,35,0.6); border-radius:6px; display:flex; align-items:center; justify-content:center; margin-bottom:14px; cursor:pointer; transition:all 0.3s;" onmouseover="this.style.background='rgba(30,30,50,0.8)'" onmouseout="this.style.background='rgba(20,20,35,0.6)'">
            <span class="font-display" style="font-size:0.85rem; letter-spacing:3px; color:var(--text-dim);">PHOTO</span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:start; gap:8px;">
            <div>
              <span class="font-mono" style={`font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; color:${p.color};`}>{p.type}</span>
              <h3 class="font-display" style="font-size:1.15rem; letter-spacing:1px; color:var(--text); margin-top:3px;">{p.title}</h3>
              <p style="font-size:0.8rem; color:var(--text-muted); margin-top:4px; line-height:1.5;">{p.desc}</p>
            </div>
            <!-- Share buttons -->
            <div style="display:flex; gap:6px; flex-shrink:0; margin-top:4px;">
              <a href={`https://www.facebook.com/sharer/sharer.php?u=https://ohsigns.shop/portfolio`} target="_blank" rel="noopener" style="width:26px; height:26px; border:1px solid var(--border); border-radius:4px; display:flex; align-items:center; justify-content:center; color:var(--text-dim); text-decoration:none; font-size:0.7rem; transition:all 0.2s;" onmouseover="this.style.borderColor='var(--blue)'; this.style.color='var(--blue)'" onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'" title="Share on Facebook">f</a>
              <a href={`https://twitter.com/intent/tweet?text=Check out this work by OH! Signs!&url=https://ohsigns.shop/portfolio`} target="_blank" rel="noopener" style="width:26px; height:26px; border:1px solid var(--border); border-radius:4px; display:flex; align-items:center; justify-content:center; color:var(--text-dim); text-decoration:none; font-size:0.7rem; transition:all 0.2s;" onmouseover="this.style.borderColor='var(--blue)'; this.style.color='var(--blue)'" onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'" title="Share on X">𝕏</a>
            </div>
          </div>
        </Card>
      ))}
    </div>
  </section>

  <!-- YouTube Videos -->
  <section style="padding:48px 24px;">
    <div style="max-width:800px; margin:0 auto;">
      <SectionTitle eyebrow="Videos" title="Behind the Scenes" accentColor="var(--yellow)" />

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(340px,1fr)); gap:16px;">
        {videos.map((v, i) => (
          <Card class={`fade-up-d${i + 1}`} style="padding:0; overflow:hidden;">
            <div style="position:relative; padding-bottom:56.25%; height:0; background:rgba(20,20,35,0.6);">
              <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; cursor:pointer;" data-video-id={v.id}>
                <div style="width:60px; height:60px; border-radius:50%; background:rgba(255,45,45,0.9); display:flex; align-items:center; justify-content:center; transition:transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                  <span style="color:white; font-size:1.5rem; margin-left:3px;">▶</span>
                </div>
              </div>
            </div>
            <div style="padding:14px 18px;">
              <h3 class="font-display" style="font-size:1rem; letter-spacing:1.5px; color:var(--text);">{v.title}</h3>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:32px 24px 60px;">
    <Card accentSide="top" accentColor="var(--blue)" class="fade-up" style="max-width:680px; margin:0 auto; text-align:center; padding:44px 32px;">
      <h2 class="font-display section-heading">
        Like What You See?
      </h2>
      <p style="font-size:0.95rem; color:var(--text-muted); margin-bottom:24px;">
        Let's create something great for your business.
      </p>
      <Btn href="/quote" variant="cta">GET A FREE QUOTE →</Btn>
    </Card>
  </section>

</Layout>

<script>
  document.querySelectorAll('[data-video-id]').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-video-id');
      const wrapper = el.parentElement!;
      wrapper.innerHTML = `<iframe src="https://www.youtube.com/embed/${id}?autoplay=1" style="position:absolute;inset:0;width:100%;height:100%;border:none;" allow="autoplay;encrypted-media" allowfullscreen></iframe>`;
    });
  });
</script>
