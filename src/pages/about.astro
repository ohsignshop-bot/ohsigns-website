---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Card from '../components/Card.astro';
import Btn from '../components/Btn.astro';

const values = [
  { icon: '🤝', title: 'We Keep It Personal', desc: 'You work directly with us — no call centers, no middlemen. Your project gets our full attention.', color: 'var(--blue)' },
  { icon: '⚡', title: 'Fast Without Cutting Corners', desc: 'We know your deadline matters. We move fast and deliver quality every time.', color: 'var(--yellow)' },
  { icon: '🎨', title: 'Design Is Part of the Deal', desc: "No designer? No problem. We help bring your vision to life from concept to final product.", color: 'var(--red)' },
  { icon: '📍', title: 'Rooted in the Community', desc: "We're a local Winston-Salem business serving local businesses. When you win, we win.", color: 'var(--blue)' },
];

const stats = [
  { num: '500+', label: 'Signs Made' },
  { num: '100%', label: 'Custom' },
  { num: '5★', label: 'Reviews' },
];
---

<Layout title="About" description="Family-owned sign shop in Winston-Salem, NC. Custom signs, banners, wraps & more.">

  <!-- Hero -->
  <section style="padding:100px 24px 48px; text-align:center;">
    <div style="max-width:680px; margin:0 auto;">
      <p class="fade-up section-eyebrow">Our Story</p>
      <h1 class="fade-up-d1 font-display" style="font-size:clamp(2.6rem,7vw,4.5rem); line-height:1.05; letter-spacing:3px; margin-bottom:14px;">
        Built by Makers,<br /><span style="color:var(--blue);">For Businesses.</span>
      </h1>
      <div class="fade-up-d2 accent-line" style="background:var(--red); margin:0 auto;"></div>
    </div>
  </section>

  <!-- Story -->
  <section style="padding:32px 24px 48px;">
    <div style="max-width:800px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:28px; align-items:center;">
      <div class="fade-up-d1">
        <div style="display:flex; flex-direction:column; gap:14px; font-size:0.92rem; color:var(--text-muted); line-height:1.7;">
          <p>OH! Signs was born from a simple idea: every business deserves great signage, and getting it shouldn't be complicated or overpriced.</p>
          <p>We're a family-owned shop based in Winston-Salem, NC, helping local businesses make their mark with custom signs, wraps, banners, and more.</p>
          <p>From a small window decal to a full vehicle fleet wrap — we handle it all with the same attention to detail and personal service.</p>
        </div>
      </div>
      <Card accentSide="top" accentColor="var(--blue)" class="fade-up-d2" style="text-align:center; padding:32px;">
        <div class="font-display" style="font-size:3.5rem; color:var(--blue); animation:float 5s ease-in-out infinite;">OH!</div>
        <div class="font-display" style="font-size:1.4rem; letter-spacing:2px; color:var(--text); margin:6px 0 10px;">Every Sign Tells<br />Your Story.</div>
        <p style="font-size:0.82rem; color:var(--text-muted); line-height:1.6;">Quality materials, sharp design, and a process that respects your time and budget.</p>
      </Card>
    </div>
  </section>

  <!-- Stats -->
  <section style="padding:32px 24px;">
    <div style="max-width:420px; margin:0 auto; display:grid; grid-template-columns:repeat(3,1fr); gap:14px; text-align:center;">
      {stats.map((s, i) => (
        <div class={`fade-up-d${i + 1}`}>
          <div class="stat-num font-display" style={`font-size:2.2rem; letter-spacing:2px; animation:float ${4 + i}s ease-in-out infinite;`}>{s.num}</div>
          <div class="font-mono" style="font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; color:var(--text-dim); margin-top:4px;">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Values -->
  <section style="padding:48px 24px;">
    <div style="max-width:900px; margin:0 auto;">
      <SectionTitle eyebrow="Our Values" title="What Makes Us Different" accentColor="var(--yellow)" />

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px;">
        {values.map((v, i) => (
          <Card accentColor={v.color} class={`fade-up-d${(i % 3) + 1}`}>
            <div style={`font-size:1.6rem; margin-bottom:8px; animation:float ${3 + i}s ease-in-out infinite;`}>{v.icon}</div>
            <h3 class="font-display" style="font-size:1.2rem; letter-spacing:2px; color:var(--text); margin-bottom:4px;">{v.title}</h3>
            <p style="font-size:0.82rem; color:var(--text-muted); line-height:1.6;">{v.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Google Maps placeholder -->
  <section style="padding:32px 24px;">
    <div style="max-width:700px; margin:0 auto;">
      <SectionTitle eyebrow="Find Us" title="Located in Winston-Salem, NC" accentColor="var(--blue)" />
      <div class="glass-card fade-up" style="padding:0; overflow:hidden; height:300px; display:flex; align-items:center; justify-content:center;">
        <div style="text-align:center; color:var(--text-dim);">
          <div style="font-size:2rem; margin-bottom:8px;">📍</div>
          <p class="font-mono" style="font-size:0.75rem; letter-spacing:1px;">Google Maps embed coming soon</p>
          <p style="font-size:0.85rem; margin-top:8px;">Winston-Salem, NC</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:48px 24px;">
    <div style="max-width:680px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:28px; align-items:center;">
      <div class="fade-up">
        <p class="section-eyebrow">Get In Touch</p>
        <h2 class="font-display" style="font-size:2rem; letter-spacing:2px; color:var(--text); margin-bottom:14px;">Let's Talk About<br />Your Next Project.</h2>
        <div style="display:flex; flex-direction:column; gap:6px; font-size:0.85rem; color:var(--text-muted);">
          <div style="display:flex; align-items:center; gap:6px;"><span style="color:var(--blue);">✉</span> <a href="mailto:info@ohsigns.shop" class="hover-line" style="color:var(--text-muted); text-decoration:none;">info@ohsigns.shop</a></div>
          <div style="display:flex; align-items:center; gap:6px;"><span style="color:var(--blue);">📍</span> Winston-Salem, NC</div>
        </div>
      </div>
      <div class="fade-up-d2" style="display:flex; flex-direction:column; gap:10px;">
        <Btn href="/quote" variant="cta">GET A FREE QUOTE</Btn>
        <Btn href="/shop" variant="outline">BROWSE THE SHOP</Btn>
      </div>
    </div>
  </section>

</Layout>
