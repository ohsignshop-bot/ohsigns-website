---
import Layout from '../layouts/Layout.astro';

const values = [
  { icon: '🤝', title: 'We Keep It Personal', desc: 'You work directly with us — no call centers, no middlemen. Your project gets our full attention.', color: '#3B9AE1' },
  { icon: '⚡', title: 'Fast Without Cutting Corners', desc: 'We know your deadline matters. We move fast and deliver quality every time.', color: '#FFE600' },
  { icon: '🎨', title: 'Design Is Part of the Deal', desc: "No designer? No problem. We help bring your vision to life from concept to final product.", color: '#E84020' },
  { icon: '📍', title: 'Rooted in the Community', desc: "We're a local Winston-Salem business serving local businesses. When you win, we win.", color: '#3B9AE1' },
];

const stats = [
  { num: '500+', label: 'Signs Made' },
  { num: '100%', label: 'Custom' },
  { num: '5★', label: 'Reviews' },
];
---

<Layout title="About" description="Family-owned sign shop in Winston-Salem, NC. Custom signs, banners, wraps & more.">

  <!-- Hero -->
  <section style="padding:100px 24px 60px; text-align:center;">
    <div style="max-width:700px; margin:0 auto;">
      <p class="fade-up" style="font-family:'Bebas Neue',sans-serif; font-size:0.85rem; letter-spacing:6px; color:#707080; text-transform:uppercase; margin-bottom:16px;">Our Story</p>
      <h1 class="fade-up-d1 font-display title-layered" data-text="Built by Makers, For Businesses." style="font-size:clamp(2.8rem,7vw,5rem); line-height:1.05; letter-spacing:3px; margin-bottom:16px;">
        Built by Makers,<br /><span style="color:#3B9AE1;">For Businesses.</span>
      </h1>
      <div class="fade-up-d2 accent-line" style="background:#E84020; margin:0 auto;"></div>
    </div>
  </section>

  <!-- Story -->
  <section style="padding:40px 24px 60px;">
    <div style="max-width:800px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:30px; align-items:center;">
      <div class="fade-up-d1">
        <div style="display:flex; flex-direction:column; gap:16px; font-size:0.95rem; color:#707080; line-height:1.7;">
          <p>OH! Signs was born from a simple idea: every business deserves great signage, and getting it shouldn't be complicated or overpriced.</p>
          <p>We're a family-owned shop based in Winston-Salem, NC, and we've been helping local businesses make their mark with custom signs, wraps, banners, and more.</p>
          <p>From a small window decal to a full vehicle fleet wrap — we handle it all with the same attention to detail and personal service.</p>
        </div>
      </div>
      <div class="glass-card fade-up-d2" style="border-top:3px solid #3B9AE1; text-align:center; padding:36px;">
        <div class="font-display" style="font-size:4rem; color:#3B9AE1; animation:floatSlow 5s ease-in-out infinite;">OH!</div>
        <div class="font-display" style="font-size:1.6rem; letter-spacing:2px; color:#F5F5F5; margin:8px 0 12px;">Every Sign Tells<br />Your Story.</div>
        <p style="font-size:0.85rem; color:#707080; line-height:1.6;">Quality materials, sharp design, and a process that respects your time and budget.</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section style="padding:40px 24px;">
    <div style="max-width:500px; margin:0 auto; display:grid; grid-template-columns:repeat(3,1fr); gap:16px; text-align:center;">
      {stats.map((s, i) => (
        <div class={`fade-up-d${i + 1}`}>
          <div class="font-display stat-pop" style={`font-size:2.5rem; letter-spacing:2px; color:#FFE600; animation:float ${4 + i}s ease-in-out infinite;`}>{s.num}</div>
          <div style="font-size:0.75rem; letter-spacing:2px; text-transform:uppercase; color:#707080; margin-top:4px;">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Values -->
  <section style="padding:60px 24px;">
    <div style="max-width:900px; margin:0 auto;">
      <div class="fade-up" style="text-align:center; margin-bottom:48px;">
        <h2 class="font-display title-layered" data-text="What Makes Us Different" style="font-size:clamp(2rem,4vw,3rem); letter-spacing:3px; color:#F5F5F5; margin-bottom:8px;">What Makes Us Different</h2>
        <div class="accent-line" style="background:#FFE600; margin:0 auto;"></div>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:16px;">
        {values.map((v, i) => (
          <div class={`glass-card-3d fade-up-d${(i % 3) + 1}`} style={`border-left:3px solid ${v.color};`}>
            <div style={`font-size:1.8rem; margin-bottom:10px; animation:float ${3 + i}s ease-in-out infinite;`}>{v.icon}</div>
            <h3 class="font-display" style="font-size:1.3rem; letter-spacing:2px; color:#F5F5F5; margin-bottom:6px;">{v.title}</h3>
            <p style="font-size:0.85rem; color:#707080; line-height:1.6;">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:60px 24px;">
    <div style="max-width:700px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:30px; align-items:center;">
      <div class="fade-up">
        <p style="font-family:'Bebas Neue',sans-serif; font-size:0.8rem; letter-spacing:4px; color:#3a3a55; margin-bottom:8px;">GET IN TOUCH</p>
        <h2 class="font-display" style="font-size:2.2rem; letter-spacing:2px; color:#F5F5F5; margin-bottom:16px;">Let's Talk About<br />Your Next Project.</h2>
        <div style="display:flex; flex-direction:column; gap:8px; font-size:0.9rem; color:#707080;">
          <div style="display:flex; align-items:center; gap:8px;"><span style="color:#3B9AE1;">✉</span> <a href="mailto:info@ohsigns.shop" style="color:#707080; text-decoration:none;" onmouseover="this.style.color='#F5F5F5'" onmouseout="this.style.color='#707080'">info@ohsigns.shop</a></div>
          <div style="display:flex; align-items:center; gap:8px;"><span style="color:#3B9AE1;">📍</span> Winston-Salem, NC</div>
        </div>
      </div>
      <div class="fade-up-d2" style="display:flex; flex-direction:column; gap:12px;">
        <div class="cta-stack">
          <div class="layer layer-blue"></div>
          <div class="layer layer-red"></div>
          <a href="/quote" class="layer-main" style="padding:14px 28px;">GET A FREE QUOTE</a>
        </div>
        <a href="/shop" style="border:1.5px solid #3a3a4a; color:#A0A0B8; font-family:'Bebas Neue',sans-serif; font-size:1.1rem; letter-spacing:3px; padding:14px 28px; border-radius:20px; text-align:center; text-decoration:none; transition:all 0.25s;" onmouseover="this.style.borderColor='#F5F5F5'; this.style.color='#F5F5F5'" onmouseout="this.style.borderColor='#3a3a4a'; this.style.color='#A0A0B8'">BROWSE THE SHOP</a>
      </div>
    </div>
  </section>

</Layout>
