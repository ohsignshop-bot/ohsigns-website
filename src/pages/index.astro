---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Card from '../components/Card.astro';
import Btn from '../components/Btn.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';
import { portfolio } from '../data/portfolio';

const trust = [
  { num: '500+', label: 'Signs Made' },
  { num: '24hr', label: 'Quote Response' },
  { num: '100%', label: 'Custom Work' },
  { num: 'NC', label: 'Local Business' },
];

const tags = ['Vinyl Decals', 'Fine-Art Prints', 'Business Branding', 'UV Prints', 'Print/Copy Services'];
---

<Layout title="Home" description="OH! Signs — Custom signs, banners, vehicle wraps & more. Handcrafted in Winston-Salem, NC.">

  <!-- ── HERO ──────────────────────────────────────── -->
  <section style="position:relative; padding:80px 24px 60px; text-align:center; overflow:hidden;">
    <div style="position:absolute; top:-80px; left:50%; transform:translateX(-50%); width:600px; height:350px; background:radial-gradient(ellipse,rgba(0,153,255,0.08) 0%,transparent 70%); pointer-events:none;"></div>

    <div style="max-width:760px; margin:0 auto; position:relative;">

      <!-- Logo -->
      <div class="fade-up" style="margin-bottom:14px;">
        <span style="font-family:'Bebas Neue',sans-serif; font-size:3.2rem; letter-spacing:2px; color:var(--red);">OH!</span>
        <span style="font-family:'Dancing Script',cursive; font-size:4rem; color:var(--blue); position:relative; top:3px;">Signs</span>
      </div>

      <!-- Eyebrow -->
      <p class="fade-up-d1 font-mono" style="font-size:0.75rem; letter-spacing:4px; color:var(--text-dim); text-transform:uppercase; margin-bottom:20px;">
        Winston-Salem, NC — Custom Sign Shop
      </p>

      <!-- Paint stroke -->
      <div class="fade-up-d1" style="max-width:420px; margin:0 auto 28px; height:6px; border-radius:3px; background:linear-gradient(90deg, var(--red) 0%, var(--yellow) 35%, var(--blue) 65%, var(--red) 100%); background-size:200% 100%; animation:shimmer 4s linear infinite;"></div>

      <!-- Headline -->
      <div class="fade-up-d2" style="margin-bottom:20px;">
        <h1 class="font-display" style="font-size:clamp(3rem,9vw,6.5rem); line-height:0.95; letter-spacing:4px; margin:0;">
          <span style="display:block; color:var(--text);">CREATE.</span>
          <span style="display:block; color:var(--red);">PRINT.</span>
          <span style="display:block; color:var(--yellow);">IMPRESS.</span>
        </h1>
      </div>

      <!-- Sub-copy -->
      <p class="fade-up-d3" style="font-size:1rem; color:var(--text-muted); line-height:1.75; max-width:540px; margin:0 auto 24px;">
        Small shop, big output — Fine-art prints, vinyl decals, custom signs, UV print &amp; one-off designs built for artists and businesses that want to stand out. Taking orders now.
      </p>

      <!-- Service tags -->
      <div class="fade-up-d3" style="display:flex; flex-wrap:wrap; gap:8px; justify-content:center; margin-bottom:32px;">
        {tags.map((tag, i) => (
          <span class="tag" style={`border-color:${['var(--blue)','var(--red)','var(--yellow)','var(--blue)','var(--red)'][i]}40; color:${['var(--blue)','var(--red)','var(--yellow)','var(--blue)','var(--red)'][i]};`}>
            {tag.toUpperCase()}
          </span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="fade-up-d4" style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center; align-items:center;">
        <Btn href="/quote" variant="cta">GET A FREE QUOTE</Btn>
        <Btn href="/shop" variant="outline">SHOP NOW</Btn>
      </div>

      <!-- Bottom info -->
      <p class="fade-up-d5 font-mono" style="font-size:0.65rem; letter-spacing:3px; color:var(--text-dim); text-transform:uppercase; margin-top:28px;">
        info@ohsigns.shop &nbsp;—&nbsp; fast response &nbsp;—&nbsp; quality work
      </p>

    </div>
  </section>

  <!-- ── SERVICES PREVIEW ──────────────────────────── -->
  <section style="padding:60px 24px;">
    <div style="max-width:960px; margin:0 auto;">
      <SectionTitle eyebrow="What We Do" title="Our Services" subtitle="Signs, graphics & wraps for every business." accentColor="var(--red)" />

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px;">
        {services.slice(0, 6).map((s, i) => (
          <Card accentColor={s.color} class={`fade-up-d${(i % 3) + 1}`}>
            <div style={`font-size:1.6rem; margin-bottom:8px; animation:float ${3 + (i % 3)}s ease-in-out infinite;`}>{s.icon}</div>
            <h3 class="font-display" style={`font-size:1.25rem; letter-spacing:2px; color:${s.color}; margin-bottom:4px;`}>{s.title}</h3>
            <p style="font-size:0.82rem; color:var(--text-muted); line-height:1.55;">{s.desc}</p>
          </Card>
        ))}
      </div>

      <div style="text-align:center; margin-top:28px;">
        <Btn href="/services" variant="outline" size="sm">VIEW ALL SERVICES →</Btn>
      </div>
    </div>
  </section>

  <!-- ── TRUST STATS ───────────────────────────────── -->
  <section style="padding:40px 24px;">
    <div style="max-width:640px; margin:0 auto; display:grid; grid-template-columns:repeat(4,1fr); gap:12px; text-align:center;">
      {trust.map((t, i) => (
        <div class={`fade-up-d${i + 1}`}>
          <div class="stat-num font-display" style={`font-size:clamp(1.8rem,4vw,2.8rem); letter-spacing:2px; animation:float ${4 + i}s ease-in-out infinite;`}>{t.num}</div>
          <div class="font-mono" style="font-size:0.65rem; letter-spacing:2px; text-transform:uppercase; color:var(--text-dim); margin-top:4px;">{t.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── TESTIMONIALS ──────────────────────────────── -->
  <section style="padding:60px 24px;">
    <div style="max-width:960px; margin:0 auto;">
      <SectionTitle eyebrow="What Customers Say" title="Reviews" accentColor="var(--yellow)" />

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:14px;">
        {testimonials.slice(0, 3).map((t, i) => (
          <Card class={`fade-up-d${i + 1}`}>
            <div style="margin-bottom:12px;">
              {Array.from({length: t.rating}).map(() => (
                <span style="color:var(--yellow); font-size:0.9rem;">★</span>
              ))}
            </div>
            <p style="font-size:0.88rem; color:var(--text-muted); line-height:1.65; margin-bottom:16px; font-style:italic;">"{t.quote}"</p>
            <div>
              <div class="font-display" style="font-size:0.95rem; letter-spacing:1px; color:var(--text);">{t.author}</div>
              <div class="font-mono" style="font-size:0.65rem; letter-spacing:1px; color:var(--text-dim);">{t.company}</div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PORTFOLIO PREVIEW ─────────────────────────── -->
  <section style="padding:60px 24px;">
    <div style="max-width:960px; margin:0 auto;">
      <SectionTitle eyebrow="Our Work" title="Recent Projects" subtitle="A few things we've been working on." accentColor="var(--blue)" />

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:14px;">
        {portfolio.slice(0, 4).map((p, i) => (
          <Card accentColor={p.color} class={`fade-up-d${(i % 3) + 1}`}>
            <div style="width:100%; height:130px; background:rgba(20,20,35,0.6); border-radius:6px; display:flex; align-items:center; justify-content:center; margin-bottom:14px;">
              <span class="font-display" style="font-size:0.85rem; letter-spacing:3px; color:var(--text-dim);">PHOTO</span>
            </div>
            <span class="font-mono" style={`font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; color:${p.color};`}>{p.type}</span>
            <h3 class="font-display" style="font-size:1.15rem; letter-spacing:1px; color:var(--text); margin-top:4px;">{p.title}</h3>
          </Card>
        ))}
      </div>

      <div style="text-align:center; margin-top:28px;">
        <Btn href="/portfolio" variant="outline" size="sm">VIEW ALL PROJECTS →</Btn>
      </div>
    </div>
  </section>

  <!-- ── BOTTOM CTA ────────────────────────────────── -->
  <section style="padding:60px 24px;">
    <Card accentSide="top" accentColor="var(--blue)" class="fade-up" style="max-width:680px; margin:0 auto; text-align:center; padding:44px 32px; position:relative; overflow:hidden;">
      <div style="position:absolute; top:-40px; left:50%; transform:translateX(-50%); width:280px; height:180px; background:radial-gradient(ellipse,rgba(0,153,255,0.06) 0%,transparent 70%); pointer-events:none;"></div>
      <h2 class="font-display section-heading" style="position:relative;">
        Ready to Make<br /><span style="color:var(--blue);">Your Mark?</span>
      </h2>
      <p style="font-size:0.95rem; color:var(--text-muted); margin-bottom:24px; position:relative;">
        Send us your idea and we'll get back with a quote within 24 hours.
      </p>
      <Btn href="/quote" variant="cta">GET A FREE QUOTE →</Btn>
    </Card>
  </section>

</Layout>

<style>
  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>
