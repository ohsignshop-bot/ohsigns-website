---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Banners & Displays',
    desc: 'Vinyl banners, retractable stands, foam board — indoor or outdoor, any size.',
    color: '#3B9AE1',
  },
  {
    title: 'Vehicle Wraps',
    desc: 'Full wraps, partial wraps, and fleet graphics that turn heads on the road.',
    color: '#E84020',
  },
  {
    title: 'Wall & Window Graphics',
    desc: 'Storefront decals, wall murals, floor graphics, and frosted window film.',
    color: '#FFE600',
  },
  {
    title: 'Custom Signs',
    desc: 'Yard signs, rigid signs, acrylic, and anything else your business needs.',
    color: '#3B9AE1',
  },
];

const trust = [
  { label: 'Family Owned', icon: '🏠' },
  { label: 'Fast Turnaround', icon: '⚡' },
  { label: 'Custom Work', icon: '🎨' },
  { label: 'Winston-Salem, NC', icon: '📍' },
];
---

<Layout title="Home" description="OH! Signs — Custom signs, banners, vehicle wraps & more. Handcrafted in Winston-Salem, NC.">

  <!-- Hero -->
  <section style="padding:6rem 1.5rem 5rem; text-align:center;">
    <div class="max-w-5xl mx-auto">

      <p style="font-family:'Barlow Condensed',sans-serif; font-size:0.8rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#3B9AE1; margin-bottom:1.25rem;">
        Winston-Salem, NC · Custom Sign Shop
      </p>

      <h1 class="font-display" style="font-size:clamp(3.5rem,10vw,8rem); line-height:0.95; margin-bottom:1.5rem; color:#eaeaea;">
        Your Vision.<br />
        <span style="color:#3B9AE1;">Every</span>
        <span style="color:#E84020;"> Sign.</span>
      </h1>

      <p style="font-family:'Barlow Condensed',sans-serif; font-size:1.15rem; font-weight:500; color:#7a8090; max-width:38rem; margin:0 auto 2.5rem; line-height:1.55;">
        Banners, wraps, wall graphics, custom signs — we handle it all with care and fast turnaround.
        Tell us what you need and we'll make it happen.
      </p>

      <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
        <a
          href="/quote"
          style="background:#FFE600; color:#0a0a0f; font-family:'Barlow Condensed',sans-serif; font-size:1rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.9rem 2.25rem; border-radius:8px; text-decoration:none; box-shadow:4px 4px 0 #E84020, 8px 8px 0 #3B9AE1;"
        >
          ⚡ Get a Free Quote
        </a>
        <a
          href="/shop"
          style="border:2px solid #1e1e35; color:#7a8090; font-family:'Barlow Condensed',sans-serif; font-size:1rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.9rem 2.25rem; border-radius:8px; text-decoration:none;"
        >
          Shop Now →
        </a>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section style="background:#0f0f1a; padding:5rem 1.5rem; border-top:1px solid #1e1e35; border-bottom:1px solid #1e1e35;">
    <div class="max-w-6xl mx-auto">
      <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#3a3a55; margin-bottom:0.75rem;">What We Do</p>
      <h2 class="font-display" style="font-size:clamp(2.5rem,5vw,4rem); color:#eaeaea; margin-bottom:3rem;">
        Signs for every business.
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1.5rem;">
        {services.map(s => (
          <div style={`background:#151525; border:1px solid #1e1e35; border-top:3px solid ${s.color}; border-radius:10px; padding:2rem;`}>
            <h3 class="font-display" style={`font-size:1.75rem; color:${s.color}; margin-bottom:0.75rem;`}>{s.title}</h3>
            <p style="font-size:0.95rem; color:#7a8090; line-height:1.55;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section style="padding:3.5rem 1.5rem;">
    <div class="max-w-6xl mx-auto" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:2rem; text-align:center;">
      {trust.map(t => (
        <div>
          <div style="font-size:2rem; margin-bottom:0.5rem;">{t.icon}</div>
          <div class="font-display" style="font-size:1.35rem; color:#eaeaea;">{t.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Banner -->
  <section style="background:#0f0f1a; border:1px solid #1e1e35; border-radius:16px; margin:0 auto 5rem; padding:4rem 2rem; text-align:center; max-width:72rem;">
    <h2 class="font-display" style="font-size:clamp(2.5rem,6vw,5rem); color:#eaeaea; margin-bottom:1rem;">
      Ready to make<br /><span style="color:#3B9AE1;">your mark?</span>
    </h2>
    <p style="font-size:1.05rem; color:#7a8090; margin-bottom:2rem;">
      Send us your idea and we'll get back with a quote within 24 hours.
    </p>
    <a
      href="/quote"
      style="display:inline-block; background:#3B9AE1; color:#fff; font-family:'Barlow Condensed',sans-serif; font-size:1rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.9rem 2.5rem; border-radius:8px; text-decoration:none;"
    >
      Get a Free Quote →
    </a>
  </section>

</Layout>
