---
// OH! Signs — Coming Soon / Landing Page
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="OH! Signs — Custom signs, vinyl decals, business branding, UV prints & one-off designs. Winston-Salem, NC." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Bebas+Neue&family=Barlow+Condensed:wght@400;700;900&display=swap" rel="stylesheet" />
  <title>OH! Signs — Custom Signs & Decals</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --blue:   #3B9AE1;
      --red:    #E84020;
      --yellow: #FFE600;
      --bg:     #0a0a0f;
      --fg:     #eaeaea;
    }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: 'Barlow Condensed', Arial, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .dots {
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, #1c1c30 1.2px, transparent 1.2px);
      background-size: 24px 24px;
      opacity: .5;
      pointer-events: none;
      z-index: 0;
    }

    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(90px);
      opacity: .12;
      pointer-events: none;
      z-index: 0;
    }
    .b1 { width: 420px; height: 420px; background: var(--blue);   top: -130px;  left: -130px; }
    .b2 { width: 380px; height: 380px; background: var(--yellow); bottom: -110px; right: -110px; }
    .b3 { width: 260px; height: 260px; background: var(--red);    top: 40%;     left: 60%; }

    .wrap {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .drip {
      height: 10px;
      background: repeating-linear-gradient(90deg,
        var(--blue)   0     50px,
        var(--yellow) 50px  100px,
        var(--red)    100px 150px,
        #111          150px 200px
      );
    }

    .ticker {
      background: var(--yellow);
      color: var(--bg);
      padding: 8px 0;
      overflow: hidden;
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: .95rem;
      letter-spacing: 3px;
      white-space: nowrap;
    }
    .tick-inner {
      display: inline-flex;
      animation: marquee 22s linear infinite;
    }
    .tick-inner span { padding: 0 28px; }
    .tick-inner span::before { content: '✦ '; color: var(--red); }
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 48px 20px 36px;
    }

    .logo-wrap {
      margin-bottom: 28px;
      animation: dropIn .65s cubic-bezier(.34,1.56,.64,1) both;
    }
    .logo-wrap img {
      height: 90px;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 4px 24px rgba(59,154,225,.25)) drop-shadow(0 2px 8px rgba(232,64,32,.15));
    }

    .headline {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: clamp(3.2rem, 9vw, 6.5rem);
      line-height: .95;
      letter-spacing: 2px;
      margin-bottom: 20px;
      animation: dropIn .7s cubic-bezier(.34,1.56,.64,1) .1s both;
    }
    .l1 { display: block; color: var(--fg); }
    .l2 { display: block; color: var(--blue); position: relative; margin-bottom: 8px; }
    .brush {
      display: block;
      height: 7px;
      background: var(--yellow);
      border-radius: 4px;
      width: 68%;
      margin: 6px auto 0;
      transform: rotate(-1.2deg);
      opacity: .85;
    }
    .l3 { display: block; color: var(--red); font-size: 76%; }

    .subtext {
      max-width: 510px;
      font-size: 1.12rem;
      font-weight: 400;
      color: #999;
      line-height: 1.65;
      margin-bottom: 30px;
      animation: fadeUp .6s ease .25s both;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin-bottom: 34px;
      animation: fadeUp .6s ease .35s both;
    }
    .tag {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: .9rem;
      letter-spacing: 2px;
      padding: 7px 16px;
      border: 2px solid;
      border-radius: 4px;
      cursor: default;
      transition: transform .2s, box-shadow .2s;
    }
    .tag:nth-child(1) { border-color: var(--blue);   color: var(--blue); }
    .tag:nth-child(2) { border-color: var(--yellow);  color: var(--yellow); }
    .tag:nth-child(3) { border-color: var(--red);     color: var(--red); }
    .tag:nth-child(4) { border-color: var(--blue);    color: var(--blue); }
    .tag:nth-child(5) { border-color: var(--yellow);  color: var(--yellow); }
    .tag:hover { transform: translateY(-3px) rotate(-1.5deg); box-shadow: 0 6px 18px rgba(0,0,0,.5); }

    .cta-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      animation: fadeUp .6s ease .45s both;
    }
    .cta {
      display: inline-block;
      background: var(--yellow);
      color: var(--bg);
      padding: 15px 34px;
      border-radius: 5px;
      text-decoration: none;
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 1.35rem;
      letter-spacing: 3px;
      box-shadow: 5px 5px 0 var(--blue), 10px 10px 0 var(--red);
      transition: transform .15s, box-shadow .15s;
      cursor: pointer;
      border: none;
    }
    .cta:hover {
      transform: translate(-3px, -3px);
      box-shadow: 8px 8px 0 var(--blue), 14px 14px 0 var(--red);
    }
    .cta:active {
      transform: translate(3px, 3px);
      box-shadow: 2px 2px 0 var(--blue), 4px 4px 0 var(--red);
    }
    .note {
      font-family: 'Permanent Marker', cursive;
      font-size: .82rem;
      color: #444;
    }

    .socials {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-top: 34px;
      animation: fadeUp .6s ease .55s both;
    }
    .slink {
      width: 42px;
      height: 42px;
      border: 2px solid #222;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      color: #555;
      transition: border-color .2s, color .2s, transform .2s;
    }
    .slink:hover {
      border-color: var(--blue);
      color: var(--blue);
      transform: translateY(-3px) rotate(5deg);
    }

    footer {
      text-align: center;
      padding: 20px;
      font-size: .76rem;
      color: #2a2a2a;
      letter-spacing: 2px;
      font-family: 'Barlow Condensed', sans-serif;
      position: relative;
      z-index: 1;
    }

    /* ── MODAL ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.75);
      z-index: 100;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: #0f0f1a;
      border: 1px solid #1e1e35;
      border-top: 3px solid var(--blue);
      border-radius: 12px;
      padding: 36px;
      width: 100%;
      max-width: 460px;
      position: relative;
      animation: fadeUp .25s ease both;
    }
    .modal-close {
      position: absolute;
      top: 14px; right: 16px;
      background: none; border: none;
      color: #555; font-size: 1.4rem;
      cursor: pointer; line-height: 1;
    }
    .modal-close:hover { color: #eaeaea; }
    .modal h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      color: var(--fg);
      margin-bottom: 4px;
    }
    .modal p {
      font-size: .9rem;
      color: #666;
      margin-bottom: 20px;
    }
    .field { margin-bottom: 14px; }
    .field label {
      display: block;
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: #3a3a55;
      margin-bottom: 5px;
    }
    .field input,
    .field textarea {
      width: 100%;
      background: #151525;
      border: 1px solid #1e1e35;
      border-radius: 6px;
      padding: 10px 12px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1rem;
      color: #eaeaea;
      outline: none;
      transition: border-color .2s;
    }
    .field input:focus,
    .field textarea:focus { border-color: var(--blue); }
    .field textarea { resize: vertical; min-height: 80px; }
    .submit-btn {
      width: 100%;
      background: var(--blue);
      color: #fff;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: 2px;
      padding: 12px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      margin-top: 6px;
      transition: opacity .2s;
    }
    .submit-btn:hover { opacity: .85; }
    .submit-btn:disabled { opacity: .5; cursor: not-allowed; }
    .form-msg {
      margin-top: 12px;
      font-size: .9rem;
      text-align: center;
      min-height: 1.2em;
    }
    .form-msg.ok  { color: #2ecc71; }
    .form-msg.err { color: var(--red); }

    @keyframes dropIn {
      0%   { opacity: 0; transform: translateY(-28px) scale(.9); }
      100% { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes fadeUp {
      0%   { opacity: 0; transform: translateY(18px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 480px) {
      .logo-wrap img { height: 68px; }
      .modal { padding: 24px; }
    }
  </style>
</head>
<body>

<div class="dots"></div>
<div class="blob b1"></div>
<div class="blob b2"></div>
<div class="blob b3"></div>

<div class="wrap">

  <div class="drip"></div>

  <div class="ticker">
    <div class="tick-inner">
      <span>Vinyl Decals</span><span>Custom Signs</span><span>Business Branding</span><span>UV Prints</span><span>One-Off Designs</span><span>Fast Turnaround</span><span>Winston-Salem NC</span>
      <span>Vinyl Decals</span><span>Custom Signs</span><span>Business Branding</span><span>UV Prints</span><span>One-Off Designs</span><span>Fast Turnaround</span><span>Winston-Salem NC</span>
    </div>
  </div>

  <div class="hero">

    <div class="logo-wrap">
      <img src="/logo.png" alt="OH! Signs" />
    </div>

    <div class="headline">
      <span class="l1">Your Brand.</span>
      <span class="l2">
        Bigger &amp; Bolder.
        <div class="brush"></div>
      </span>
      <span class="l3">Handcrafted in NC.</span>
    </div>

    <p class="subtext">
      Small shop, big output — vinyl decals, custom signs, UV prints &amp; one-off designs
      built for businesses that want to stand out. Taking orders now.
    </p>

    <div class="tags">
      <div class="tag">Vinyl Decals</div>
      <div class="tag">Custom Signs</div>
      <div class="tag">Business Branding</div>
      <div class="tag">UV Prints</div>
      <div class="tag">One-Off Designs</div>
    </div>

    <div class="cta-group">
      <button class="cta" id="open-form">⚡ Get a Quote</button>
      <div class="note">info@ohsigns.shop &nbsp;·&nbsp; fast responses &nbsp;·&nbsp; quality work</div>
    </div>

    <div class="socials">
      <a class="slink" href="https://www.instagram.com/ohsignshop" target="_blank" rel="noopener" title="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a class="slink" href="https://www.facebook.com/OhSignShop" target="_blank" rel="noopener" title="Facebook">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
      <a class="slink" href="mailto:ohsignshop@gmail.com" title="Email">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </a>
    </div>

  </div>

  <footer>&copy; {new Date().getFullYear()} OH! SIGNS LLC &nbsp;&middot;&nbsp; WINSTON-SALEM, NC</footer>

</div>

<!-- Quote Request Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" id="close-modal" aria-label="Close">&times;</button>
    <h2>Get a Quote</h2>
    <p>Fill out the form and we'll get back to you within 24 hours.</p>
    <form id="contact-form" novalidate>
      <div class="field">
        <label for="c-name">Your Name *</label>
        <input type="text" id="c-name" placeholder="Jane Smith" required />
      </div>
      <div class="field">
        <label for="c-email">Email *</label>
        <input type="email" id="c-email" placeholder="jane@business.com" required />
      </div>
      <div class="field">
        <label for="c-phone">Phone</label>
        <input type="tel" id="c-phone" placeholder="(555) 000-0000" />
      </div>
      <div class="field">
        <label for="c-message">What do you need?</label>
        <textarea id="c-message" placeholder="Tell us about your project — type of sign, size, quantity, deadline…"></textarea>
      </div>
      <button type="submit" class="submit-btn" id="submit-btn">SEND REQUEST</button>
      <div class="form-msg" id="form-msg"></div>
    </form>
  </div>
</div>

<script>
  const BMS_URL = 'https://bms.ohsigns.shop';

  const openBtn  = document.getElementById('open-form');
  const closeBtn = document.getElementById('close-modal');
  const overlay  = document.getElementById('modal');

  openBtn?.addEventListener('click', () => overlay?.classList.add('open'));
  closeBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });

  const form      = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msgEl     = document.getElementById('form-msg')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    msgEl.textContent = '';
    msgEl.className = 'form-msg';

    const name    = (document.getElementById('c-name') as HTMLInputElement).value.trim();
    const email   = (document.getElementById('c-email') as HTMLInputElement).value.trim();
    const phone   = (document.getElementById('c-phone') as HTMLInputElement).value.trim();
    const message = (document.getElementById('c-message') as HTMLTextAreaElement).value.trim();

    if (!name || !email) {
      msgEl.textContent = 'Name and email are required.';
      msgEl.className = 'form-msg err';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(`${BMS_URL}/api/public/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone, message }),
      });
      if (!res.ok) throw new Error();
      msgEl.textContent = "✓ Sent! We'll be in touch within 24 hours.";
      msgEl.className = 'form-msg ok';
      form.reset();
      submitBtn.textContent = 'SENT ✓';
    } catch {
      msgEl.textContent = 'Something went wrong. Email us at info@ohsigns.shop';
      msgEl.className = 'form-msg err';
      submitBtn.disabled = false;
      submitBtn.textContent = 'SEND REQUEST';
    }
  });
</script>

</body>
</html>
