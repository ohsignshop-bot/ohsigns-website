---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="OH! Signs — Custom signs, banners, vehicle wraps & more. Coming soon to South Florida." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
    <title>OH! Signs — Coming Soon</title>
  </head>
  <body class="bg-gray-950 text-white min-h-screen flex items-center justify-center px-6" style="font-family: 'Inter', sans-serif;">

    <div class="max-w-lg w-full text-center">

      <!-- Logo -->
      <div class="font-display text-4xl mb-2">
        <span style="color:#00e5cc;">OH!</span> SIGNS
      </div>
      <p class="text-xs font-bold tracking-[4px] text-gray-500 uppercase mb-16">Sign Shop · South Florida</p>

      <!-- Main message -->
      <h1 class="font-display text-5xl md:text-6xl leading-tight mb-6">
        Something<br />
        <span style="color:#00e5cc;">great</span> is<br />
        coming.
      </h1>

      <p class="text-gray-400 text-sm leading-relaxed mb-12 max-w-sm mx-auto">
        We're putting the finishing touches on our new website.
        In the meantime, we're still open for business — reach out and let's get started on your project.
      </p>

      <!-- CTA -->
      <a
        href="mailto:info@ohsigns.shop"
        class="inline-flex items-center gap-3 bg-[#00e5cc] text-gray-900 font-bold px-8 py-4 rounded-xl text-sm tracking-wide hover:bg-[#00b8a3] transition-colors"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        info@ohsigns.shop
      </a>

      <!-- Footer -->
      <p class="text-gray-600 text-xs mt-16">&copy; {new Date().getFullYear()} OH! Signs LLC. All rights reserved.</p>

    </div>

  </body>
</html>
