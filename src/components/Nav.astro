---
const links = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Shop', href: '/shop' },
];
const tickerItems = ['UV Prints','Fast Turnaround','Vinyl Decals','Small Business','Fine-Art Prints','Business Cards','Flyers','Custom Signs','Branding','Illustrations','Lamination'];
---

<!-- Marquee Ticker -->
<div style="position:sticky; top:0; z-index:100; overflow:hidden; white-space:nowrap; padding:5px 0; font-family:'Bebas Neue',sans-serif; font-size:0.7rem; letter-spacing:3px; color:var(--bg); border-bottom:1px solid var(--border);">
  <div style="position:absolute; inset:0; display:flex;">
    {Array.from({length: 60}).map((_, i) => (
      <div style={`flex:0 0 36px; height:100%; background:${['var(--red)','var(--yellow)','var(--blue)','#1a1a24'][i % 4]};`}></div>
    ))}
  </div>
  <div style="position:relative; display:inline-flex; animation:marquee 45s linear infinite;">
    {tickerItems.map(t => <span style="padding:0 22px; font-weight:700;">{t.toUpperCase()}</span>)}
    {tickerItems.map(t => <span style="padding:0 22px; font-weight:700;">{t.toUpperCase()}</span>)}
  </div>
</div>

<!-- Nav Bar -->
<nav style="position:sticky; top:30px; z-index:99; background:rgba(10,10,15,0.88); backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); border-bottom:1px solid var(--border);">
  <div style="max-width:72rem; margin:0 auto; padding:10px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px;">

    <!-- Logo -->
    <a href="/" style="display:flex; align-items:baseline; gap:2px; text-decoration:none;">
      <span style="font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:1px; color:var(--red); font-weight:700;">OH!</span>
      <span style="font-family:'Dancing Script',cursive; font-size:1.7rem; color:var(--blue); font-weight:700;">Signs</span>
    </a>

    <!-- Links -->
    <div style="display:flex; align-items:center; gap:2px; flex-wrap:wrap;">
      {links.map(link => (
        <a
          href={link.href}
          class="hover-line"
          style="font-family:'Bebas Neue',sans-serif; font-size:0.9rem; letter-spacing:2px; color:var(--text-muted); text-decoration:none; padding:6px 12px; transition:color 0.2s;"
        >
          {link.label.toUpperCase()}
        </a>
      ))}
      <a
        href="/quote"
        data-open-quote
        class="btn btn-sm"
        style="background:var(--yellow); color:var(--bg); margin-left:8px; font-size:0.8rem; letter-spacing:2px; border:none;"
      >
        GET A FREE QUOTE
      </a>
    </div>

  </div>
</nav>
