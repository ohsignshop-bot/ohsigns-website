---
const links = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Shop', href: '/shop' },
];
const tickerItems = ['Vinyl Decals','Custom Signs','Business Branding','UV Prints','One-Off Designs','Fast Turnaround','Winston-Salem NC'];
---

<!-- Marquee Ticker -->
<div style="position:sticky; top:0; z-index:100; overflow:hidden; white-space:nowrap; padding:7px 0; font-family:'Bebas Neue',sans-serif; font-size:0.9rem; letter-spacing:3px; color:#0a0a0f; border-bottom:2px solid #2a2a32; background:repeating-linear-gradient(90deg,#E84020 0 50px,#FFE600 50px 100px,#3B9AE1 100px 150px,#111 150px 200px);">
  <div style="display:inline-flex; animation:marquee 30s linear infinite;">
    {tickerItems.map(t => <span style="padding:0 28px;">{`✦ ${t.toUpperCase()}`}</span>)}
    {tickerItems.map(t => <span style="padding:0 28px;">{`✦ ${t.toUpperCase()}`}</span>)}
  </div>
</div>

<!-- Nav Bar -->
<nav style="position:sticky; top:36px; z-index:99; background:rgba(0,0,20,0.8); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border-bottom:1px solid #2a2a3a;">
  <div style="max-width:72rem; margin:0 auto; padding:12px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px;">

    <!-- Logo -->
    <a href="/" style="display:flex; align-items:center; gap:10px; text-decoration:none;">
      <img src="/logo-icon.png" alt="OH! Signs" style="height:32px; width:auto;" />
      <span class="font-display" style="font-size:1.6rem; letter-spacing:2px; line-height:1;">
        <span style="color:#3B9AE1;">OH!</span> <span style="color:#E84020;">SIGNS</span>
      </span>
    </a>

    <!-- Links -->
    <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
      {links.map(link => (
        <a
          href={link.href}
          style="font-family:'Bebas Neue',sans-serif; font-size:0.95rem; letter-spacing:2px; color:#A0A0B8; text-decoration:none; padding:6px 14px; border-radius:20px; transition:all 0.2s;"
          onmouseover="this.style.color='#F5F5F5'"
          onmouseout="this.style.color='#A0A0B8'"
        >
          {link.label.toUpperCase()}
        </a>
      ))}
      <a
        href="/quote"
        style="font-family:'Bebas Neue',sans-serif; font-size:0.95rem; letter-spacing:2px; background:#FFE600; color:#0a0a0f; text-decoration:none; padding:6px 18px; border-radius:20px; transition:all 0.25s;"
        onmouseover="this.style.transform='translateY(-2px) scale(1.03)'"
        onmouseout="this.style.transform='none'"
      >
        GET A QUOTE
      </a>
    </div>

  </div>
</nav>
