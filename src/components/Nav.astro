---
const links = [
  { label: 'About', href: '/about' },
  { label: 'Shop', href: '/shop' },
];
---

<header class="sticky top-0 z-50" style="background:#0a0a0f; border-bottom:1px solid #1e1e35;">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img src="/logo-icon.png" alt="OH! Signs logo" style="height:36px; width:auto;" />
      <span class="font-display text-2xl tracking-wide leading-none">
        <span style="color:#3B9AE1">OH!</span> <span style="color:#E84020">SIGNS</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          style="font-family:'Barlow Condensed',sans-serif; font-size:0.95rem; font-weight:600; color:#7a8090; letter-spacing:0.05em; text-transform:uppercase; text-decoration:none; transition:color 0.2s;"
          onmouseover="this.style.color='#eaeaea'"
          onmouseout="this.style.color='#7a8090'"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/quote"
        style="background:#FFE600; color:#0a0a0f; font-family:'Barlow Condensed',sans-serif; font-size:0.9rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.55rem 1.25rem; border-radius:6px; text-decoration:none; transition:opacity 0.2s;"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        Get a Quote
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button id="menu-btn" style="background:none; border:none; color:#7a8090; cursor:pointer; padding:0.5rem;" aria-label="Open menu">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Paint drip bar -->
  <div style="height:3px; background:repeating-linear-gradient(90deg,#3B9AE1 0px,#3B9AE1 32px,#E84020 32px,#E84020 64px,#FFE600 64px,#FFE600 96px);"></div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none; border-top:1px solid #1e1e35; background:#0f0f1a; padding:1.25rem 1.5rem;">
    {links.map(link => (
      <a
        href={link.href}
        style="display:block; font-family:'Barlow Condensed',sans-serif; font-size:1rem; font-weight:600; color:#7a8090; text-transform:uppercase; letter-spacing:0.05em; padding:0.5rem 0; text-decoration:none;"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/quote"
      style="display:block; margin-top:0.75rem; background:#FFE600; color:#0a0a0f; font-family:'Barlow Condensed',sans-serif; font-size:0.9rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:0.75rem 1.25rem; border-radius:6px; text-align:center; text-decoration:none;"
    >
      Get a Quote
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    if (menu) menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
  });
</script>
